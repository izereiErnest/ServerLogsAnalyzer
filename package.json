{
  "name": "log-analyzer",
  "version": "1.0.0",
  "description": "Log Analyzer — parse and interrogate server log files",
  "main": "dist/analyze.js",
  "bin": {
    "analyze": "dist/analyze.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/analyze.ts",
    "start": "node dist/analyze.js",
    "test": "jest --testPathPattern=tests/",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.7",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ]
  }
}
